<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

   <!-- Setter injection
    <bean id="car" class="com.Abhinav.SpringDemo.Car">
    	<property name="battery" value="85"></property>
    </bean>
   -->
   
    <!-- Field injection   
    <bean id="car" class="com.Abhinav.SpringDemo.Car">
    	<property name="battery" value="85"></property>
    	<property name="engine" ref="engine"></property>
    </bean>
      <bean id="engine" class="com.Abhinav.SpringDemo.Engine">
    </bean>
    -->
    
    <!-- Constructor injection   
    <bean id="car" class="com.Abhinav.SpringDemo.Car">
    	<constructor-arg name="battery" value="69"></constructor-arg>
    	<constructor-arg name="engine" ref="engine"></constructor-arg>
    </bean>
      <bean id="engine" class="com.Abhinav.SpringDemo.Engine">
    </bean>
    -->
    
    <!-- Bean scope
    	Default scope is Singleton 
     <bean id="car" class="com.Abhinav.SpringDemo.Car"></bean>
    -->
    
    <bean id="car" class="com.Abhinav.SpringDemo.Car" scope="prototype"></bean>
   
</beans>